                "tags": [
                    "sitepackage"
                ],
                "operationId": "post_app_api_sitepackage_createsitepackage",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SitePackageType"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successfully generated.",
                        "content": {
                            "application/zip": {}
                        }
                    },
                    "400": {
                        "description": "Request malformed."
                    }
                }
            }
